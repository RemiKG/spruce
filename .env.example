# ─── Spruce environment ─────────────────────────────────────────────────────
# Copy to `.env` and fill in. NOTHING here is committed (see .gitignore).
# The app runs with NONE of these set (deterministic offline mode); each key you
# add lights up more of the real engine. The app tells you, in the UI, which
# engine is currently live.

# Server port (the client always calls relative /api, so no URL is ever hardcoded)
PORT=8787

# ── The load-bearing engine: Qwen Cloud (the design's primary, documented path) ──
# A plain pay-as-you-go `sk-...` DashScope key (NOT a Token-Plan `sk-sp-` key —
# those 401 on a deployed backend). Lights up: qwen3-vl-plus room grounding &
# concept-critic, text-embedding-v4 + qwen3-rerank style search, the qwen3.7-max
# agentic sourcing loop with web_search + web_extractor, qwen3.7-plus structured
# cart, qwen-image vision render, cosyvoice TTS.
DASHSCOPE_API_KEY=
# International (Singapore) endpoint — leave as-is unless self-hosting a proxy.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Rerank lives on the compatible-API base (NOT compatible-mode) — gotcha.
DASHSCOPE_RERANK_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# ── Fallback reasoning provider: Anthropic (used only if DASHSCOPE_API_KEY unset) ──
# Lets the natural-language + vision seams (room grounding, brief parsing, swap
# narration, concept-critic) run live even without a Qwen key. Style search then
# falls back to the deterministic lexical scorer (no neural embeddings).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Optional: live web sourcing beyond the curated catalog ──
# Only used when the Qwen path is active (web_search is a Qwen Responses built-in).
SPRUCE_ENABLE_WEB_SEARCH=false
