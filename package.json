{
  "name": "spruce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Spruce — snap your room, set a budget; an agent sources every piece for real, in stock, under your number. The picture is the cart.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "mcp": "tsx mcp/server.ts",
    "catalog:check": "tsx scripts/catalog-check.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@modelcontextprotocol/sdk": "^1.4.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
